# Copy to .env and fill in values. Never commit .env.

# --- Data warehouse (PostgreSQL) ---
DW_HOST=localhost
DW_USER=your_dw_user
DW_PASSWORD=your_dw_password

# --- Metadata catalog DB (PostgreSQL, bdw_rag_metadata) ---
# Often the same host as the DW; set explicitly if different.
METADATA_DB_HOST=localhost
METADATA_DB_USER=postgres
METADATA_DB_PASSWORD=your_metadata_password

# --- LLM (Generate SQL tab / generate_query only) ---
OPENAI_API_KEY=sk-your-key-here

# Optional — not required for core POC
ANTHROPIC_API_KEY=

# --- Services ---
MCP_SERVER_PORT=3000
MCP_DEBUG=false
GRADIO_PORT=7860
GRADIO_SHARE=false
LOG_LEVEL=INFO
